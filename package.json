{
  "name": "gevanni",
  "version": "0.1.0",
  "description": "CLI-based web application vulnerability scanner",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "gevanni": "./dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gevanni": "node src/cli/index.ts"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "files": [
    "src/",
    "bin/",
    "README.md"
  ],
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "http-proxy-agent": "^9.0.0",
    "https-proxy-agent": "^9.0.0",
    "js-yaml": "^4.1.1",
    "selfsigned": "^5.5.0"
  }
}
